{
  "name": "sample-litellm-bedrock-gateway-on-eks",
  "version": "0.1.0",
  "description": "Production-grade LiteLLM -> Amazon Bedrock gateway on EKS, built with AWS CDK. Four-layer progressive isolation (public / same-region VPCE / cross-region US profile / cross-account).",
  "license": "MIT",
  "bin": {
    "litellm-bedrock-gateway": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "destroy": "cdk destroy",
    "configure": "ts-node scripts/configure.ts",
    "detect-ip": "bash scripts/detect-ip.sh",
    "test": "jest",
    "test:unit": "jest test/unit",
    "test:snapshot": "jest test/snapshot",
    "test:update-snapshot": "jest test/snapshot -u",
    "test:e2e": "bash scripts/e2e-test.sh",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "aws-cdk": "2.1126.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@aws-cdk/lambda-layer-kubectl-v31": "^2.1.0",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.4.0",
    "js-yaml": "^4.1.0"
  }
}
